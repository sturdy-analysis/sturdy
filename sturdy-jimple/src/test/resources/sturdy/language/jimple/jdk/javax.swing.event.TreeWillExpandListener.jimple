public interface  javax.swing.event.TreeWillExpandListener extends java.lang.Object implements java.util.EventListener
{

    public abstract void treeWillExpand(javax.swing.event.TreeExpansionEvent) throws javax.swing.tree.ExpandVetoException;

    public abstract void treeWillCollapse(javax.swing.event.TreeExpansionEvent) throws javax.swing.tree.ExpandVetoException;
}
