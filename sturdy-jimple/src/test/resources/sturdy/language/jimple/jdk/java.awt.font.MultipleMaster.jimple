public interface  java.awt.font.MultipleMaster extends java.lang.Object
{

    public abstract int getNumDesignAxes();

    public abstract float[] getDesignAxisRanges();

    public abstract float[] getDesignAxisDefaults();

    public abstract java.lang.String[] getDesignAxisNames();

    public abstract java.awt.Font deriveMMFont(float[]);

    public abstract java.awt.Font deriveMMFont(float[], float, float, float, float);
}
