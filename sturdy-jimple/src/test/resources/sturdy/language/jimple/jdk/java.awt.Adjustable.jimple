public interface  java.awt.Adjustable extends java.lang.Object
{
    public static final int HORIZONTAL;
    public static final int VERTICAL;
    public static final int NO_ORIENTATION;

    public abstract int getOrientation();

    public abstract void setMinimum(int);

    public abstract int getMinimum();

    public abstract void setMaximum(int);

    public abstract int getMaximum();

    public abstract void setUnitIncrement(int);

    public abstract int getUnitIncrement();

    public abstract void setBlockIncrement(int);

    public abstract int getBlockIncrement();

    public abstract void setVisibleAmount(int);

    public abstract int getVisibleAmount();

    public abstract void setValue(int);

    public abstract int getValue();

    public abstract void addAdjustmentListener(java.awt.event.AdjustmentListener);

    public abstract void removeAdjustmentListener(java.awt.event.AdjustmentListener);

    public static void <clinit>()
    {
        <java.awt.Adjustable: int NO_ORIENTATION> = 2;

        <java.awt.Adjustable: int VERTICAL> = 1;

        <java.awt.Adjustable: int HORIZONTAL> = 0;

        return;
    }
}
