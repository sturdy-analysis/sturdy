public interface  javax.print.event.PrintJobListener extends java.lang.Object
{

    public abstract void printDataTransferCompleted(javax.print.event.PrintJobEvent);

    public abstract void printJobCompleted(javax.print.event.PrintJobEvent);

    public abstract void printJobFailed(javax.print.event.PrintJobEvent);

    public abstract void printJobCanceled(javax.print.event.PrintJobEvent);

    public abstract void printJobNoMoreEvents(javax.print.event.PrintJobEvent);

    public abstract void printJobRequiresAttention(javax.print.event.PrintJobEvent);
}
