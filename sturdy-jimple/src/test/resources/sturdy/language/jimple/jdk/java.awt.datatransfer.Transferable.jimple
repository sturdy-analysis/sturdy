public interface  java.awt.datatransfer.Transferable extends java.lang.Object
{

    public abstract java.awt.datatransfer.DataFlavor[] getTransferDataFlavors();

    public abstract boolean isDataFlavorSupported(java.awt.datatransfer.DataFlavor);

    public abstract java.lang.Object getTransferData(java.awt.datatransfer.DataFlavor) throws java.awt.datatransfer.UnsupportedFlavorException, java.io.IOException;
}
