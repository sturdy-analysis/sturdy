public interface  javax.print.URIException extends java.lang.Object
{
    public static final int URIInaccessible;
    public static final int URISchemeNotSupported;
    public static final int URIOtherProblem;

    public abstract java.net.URI getUnsupportedURI();

    public abstract int getReason();

    public static void <clinit>()
    {
        <javax.print.URIException: int URIOtherProblem> = -1;

        <javax.print.URIException: int URISchemeNotSupported> = 2;

        <javax.print.URIException: int URIInaccessible> = 1;

        return;
    }
}
