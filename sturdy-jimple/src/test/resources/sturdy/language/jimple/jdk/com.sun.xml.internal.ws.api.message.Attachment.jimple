public interface  com.sun.xml.internal.ws.api.message.Attachment extends java.lang.Object
{

    public abstract java.lang.String getContentId();

    public abstract java.lang.String getContentType();

    public abstract byte[] asByteArray();

    public abstract javax.activation.DataHandler asDataHandler();

    public abstract javax.xml.transform.Source asSource();

    public abstract java.io.InputStream asInputStream();

    public abstract void writeTo(java.io.OutputStream) throws java.io.IOException;

    public abstract void writeTo(javax.xml.soap.SOAPMessage) throws javax.xml.soap.SOAPException;
}
