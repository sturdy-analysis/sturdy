public interface  sun.management.HotspotCompilationMBean extends java.lang.Object
{

    public abstract int getCompilerThreadCount();

    public abstract java.util.List getCompilerThreadStats();

    public abstract long getTotalCompileCount();

    public abstract long getBailoutCompileCount();

    public abstract long getInvalidatedCompileCount();

    public abstract sun.management.MethodInfo getLastCompile();

    public abstract sun.management.MethodInfo getFailedCompile();

    public abstract sun.management.MethodInfo getInvalidatedCompile();

    public abstract long getCompiledMethodCodeSize();

    public abstract long getCompiledMethodSize();

    public abstract java.util.List getInternalCompilerCounters();
}
