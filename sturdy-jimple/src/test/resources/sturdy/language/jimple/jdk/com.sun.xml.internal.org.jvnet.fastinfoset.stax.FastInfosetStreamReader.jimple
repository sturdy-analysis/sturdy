public interface  com.sun.xml.internal.org.jvnet.fastinfoset.stax.FastInfosetStreamReader extends java.lang.Object
{

    public abstract int peekNext() throws javax.xml.stream.XMLStreamException;

    public abstract int accessNamespaceCount();

    public abstract java.lang.String accessLocalName();

    public abstract java.lang.String accessNamespaceURI();

    public abstract java.lang.String accessPrefix();

    public abstract char[] accessTextCharacters();

    public abstract int accessTextStart();

    public abstract int accessTextLength();
}
