public interface  com.sun.management.HotSpotDiagnosticMXBean extends java.lang.Object implements java.lang.management.PlatformManagedObject
{

    public abstract void dumpHeap(java.lang.String, boolean) throws java.io.IOException;

    public abstract java.util.List getDiagnosticOptions();

    public abstract com.sun.management.VMOption getVMOption(java.lang.String);

    public abstract void setVMOption(java.lang.String, java.lang.String);
}
