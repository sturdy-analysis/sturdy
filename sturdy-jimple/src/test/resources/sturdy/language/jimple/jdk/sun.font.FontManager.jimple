public interface  sun.font.FontManager extends java.lang.Object
{
    public static final int NO_FALLBACK;
    public static final int PHYSICAL_FALLBACK;
    public static final int LOGICAL_FALLBACK;

    public abstract boolean registerFont(java.awt.Font);

    public abstract void deRegisterBadFont(sun.font.Font2D);

    public abstract sun.font.Font2D findFont2D(java.lang.String, int, int);

    public abstract sun.font.Font2D createFont2D(java.io.File, int, boolean, sun.font.CreatedFontTracker) throws java.awt.FontFormatException;

    public abstract boolean usingPerAppContextComposites();

    public abstract sun.font.Font2DHandle getNewComposite(java.lang.String, int, sun.font.Font2DHandle);

    public abstract void preferLocaleFonts();

    public abstract void preferProportionalFonts();

    public static void <clinit>()
    {
        <sun.font.FontManager: int LOGICAL_FALLBACK> = 2;

        <sun.font.FontManager: int PHYSICAL_FALLBACK> = 1;

        <sun.font.FontManager: int NO_FALLBACK> = 0;

        return;
    }
}
