public interface  javax.script.Invocable extends java.lang.Object
{

    public abstract transient java.lang.Object invokeMethod(java.lang.Object, java.lang.String, java.lang.Object[]) throws javax.script.ScriptException, java.lang.NoSuchMethodException;

    public abstract transient java.lang.Object invokeFunction(java.lang.String, java.lang.Object[]) throws javax.script.ScriptException, java.lang.NoSuchMethodException;

    public abstract java.lang.Object getInterface(java.lang.Class);

    public abstract java.lang.Object getInterface(java.lang.Object, java.lang.Class);
}
