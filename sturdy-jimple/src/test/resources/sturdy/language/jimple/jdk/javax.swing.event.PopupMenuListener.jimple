public interface  javax.swing.event.PopupMenuListener extends java.lang.Object implements java.util.EventListener
{

    public abstract void popupMenuWillBecomeVisible(javax.swing.event.PopupMenuEvent);

    public abstract void popupMenuWillBecomeInvisible(javax.swing.event.PopupMenuEvent);

    public abstract void popupMenuCanceled(javax.swing.event.PopupMenuEvent);
}
