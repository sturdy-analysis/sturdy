public interface  java.awt.print.Pageable extends java.lang.Object
{
    public static final int UNKNOWN_NUMBER_OF_PAGES;

    public abstract int getNumberOfPages();

    public abstract java.awt.print.PageFormat getPageFormat(int) throws java.lang.IndexOutOfBoundsException;

    public abstract java.awt.print.Printable getPrintable(int) throws java.lang.IndexOutOfBoundsException;

    public static void <clinit>()
    {
        <java.awt.print.Pageable: int UNKNOWN_NUMBER_OF_PAGES> = -1;

        return;
    }
}
