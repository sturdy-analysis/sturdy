public interface  sun.rmi.transport.Connection extends java.lang.Object
{

    public abstract java.io.InputStream getInputStream() throws java.io.IOException;

    public abstract void releaseInputStream() throws java.io.IOException;

    public abstract java.io.OutputStream getOutputStream() throws java.io.IOException;

    public abstract void releaseOutputStream() throws java.io.IOException;

    public abstract boolean isReusable();

    public abstract void close() throws java.io.IOException;

    public abstract sun.rmi.transport.Channel getChannel();
}
