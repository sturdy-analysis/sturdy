public interface  java.awt.peer.DesktopPeer extends java.lang.Object
{

    public abstract boolean isSupported(java.awt.Desktop$Action);

    public abstract void open(java.io.File) throws java.io.IOException;

    public abstract void edit(java.io.File) throws java.io.IOException;

    public abstract void print(java.io.File) throws java.io.IOException;

    public abstract void mail(java.net.URI) throws java.io.IOException;

    public abstract void browse(java.net.URI) throws java.io.IOException;
}
