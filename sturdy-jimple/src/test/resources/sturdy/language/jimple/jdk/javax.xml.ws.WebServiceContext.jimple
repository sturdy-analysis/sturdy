public interface  javax.xml.ws.WebServiceContext extends java.lang.Object
{

    public abstract javax.xml.ws.handler.MessageContext getMessageContext();

    public abstract java.security.Principal getUserPrincipal();

    public abstract boolean isUserInRole(java.lang.String);

    public abstract transient javax.xml.ws.EndpointReference getEndpointReference(org.w3c.dom.Element[]);

    public abstract transient javax.xml.ws.EndpointReference getEndpointReference(java.lang.Class, org.w3c.dom.Element[]);
}
