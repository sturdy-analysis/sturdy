public interface  javax.management.remote.JMXConnectorServerMBean extends java.lang.Object
{

    public abstract void start() throws java.io.IOException;

    public abstract void stop() throws java.io.IOException;

    public abstract boolean isActive();

    public abstract void setMBeanServerForwarder(javax.management.remote.MBeanServerForwarder);

    public abstract java.lang.String[] getConnectionIds();

    public abstract javax.management.remote.JMXServiceURL getAddress();

    public abstract java.util.Map getAttributes();

    public abstract javax.management.remote.JMXConnector toJMXConnector(java.util.Map) throws java.io.IOException;
}
