public interface  sun.dc.path.PathConsumer extends java.lang.Object
{

    public abstract void beginPath() throws sun.dc.path.PathError;

    public abstract void beginSubpath(float, float) throws sun.dc.path.PathError;

    public abstract void appendLine(float, float) throws sun.dc.path.PathError;

    public abstract void appendQuadratic(float, float, float, float) throws sun.dc.path.PathError;

    public abstract void appendCubic(float, float, float, float, float, float) throws sun.dc.path.PathError;

    public abstract void closedSubpath() throws sun.dc.path.PathError;

    public abstract void endPath() throws sun.dc.path.PathError, sun.dc.path.PathException;

    public abstract void useProxy(sun.dc.path.FastPathProducer) throws sun.dc.path.PathError, sun.dc.path.PathException;

    public abstract long getCPathConsumer();

    public abstract void dispose();

    public abstract sun.dc.path.PathConsumer getConsumer();
}
