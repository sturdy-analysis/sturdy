public interface  javax.security.sasl.SaslServerFactory extends java.lang.Object
{

    public abstract javax.security.sasl.SaslServer createSaslServer(java.lang.String, java.lang.String, java.lang.String, java.util.Map, javax.security.auth.callback.CallbackHandler) throws javax.security.sasl.SaslException;

    public abstract java.lang.String[] getMechanismNames(java.util.Map);
}
