public interface  java.awt.Transparency extends java.lang.Object
{
    public static final int OPAQUE;
    public static final int BITMASK;
    public static final int TRANSLUCENT;

    public abstract int getTransparency();

    public static void <clinit>()
    {
        <java.awt.Transparency: int TRANSLUCENT> = 3;

        <java.awt.Transparency: int BITMASK> = 2;

        <java.awt.Transparency: int OPAQUE> = 1;

