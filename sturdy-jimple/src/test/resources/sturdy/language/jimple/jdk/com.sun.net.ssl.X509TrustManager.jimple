public interface  com.sun.net.ssl.X509TrustManager extends java.lang.Object implements com.sun.net.ssl.TrustManager
{

    public abstract boolean isClientTrusted(java.security.cert.X509Certificate[]);

    public abstract boolean isServerTrusted(java.security.cert.X509Certificate[]);

    public abstract java.security.cert.X509Certificate[] getAcceptedIssuers();
}
