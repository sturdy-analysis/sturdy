        <com.sun.xml.internal.stream.dtd.nonvalidating.DTDGrammar: int CHUNK_SHIFT> = 8;

        <com.sun.xml.internal.stream.dtd.nonvalidating.DTDGrammar: int TOP_LEVEL_SCOPE> = -1;

        return;
    }
}
