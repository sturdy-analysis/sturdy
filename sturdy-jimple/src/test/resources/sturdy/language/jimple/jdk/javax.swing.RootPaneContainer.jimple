public interface  javax.swing.RootPaneContainer extends java.lang.Object
{

    public abstract javax.swing.JRootPane getRootPane();

    public abstract void setContentPane(java.awt.Container);

    public abstract java.awt.Container getContentPane();

    public abstract void setLayeredPane(javax.swing.JLayeredPane);

    public abstract javax.swing.JLayeredPane getLayeredPane();

    public abstract void setGlassPane(java.awt.Component);

    public abstract java.awt.Component getGlassPane();
}
