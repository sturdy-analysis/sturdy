public interface  java.rmi.activation.ActivationMonitor extends java.lang.Object implements java.rmi.Remote
{

    public abstract void inactiveObject(java.rmi.activation.ActivationID) throws java.rmi.activation.UnknownObjectException, java.rmi.RemoteException;

    public abstract void activeObject(java.rmi.activation.ActivationID, java.rmi.MarshalledObject) throws java.rmi.activation.UnknownObjectException, java.rmi.RemoteException;

    public abstract void inactiveGroup(java.rmi.activation.ActivationGroupID, long) throws java.rmi.activation.UnknownGroupException, java.rmi.RemoteException;
}
