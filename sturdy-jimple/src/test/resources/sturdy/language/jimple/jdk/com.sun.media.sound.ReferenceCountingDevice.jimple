public interface  com.sun.media.sound.ReferenceCountingDevice extends java.lang.Object
{

    public abstract javax.sound.midi.Receiver getReceiverReferenceCounting() throws javax.sound.midi.MidiUnavailableException;

    public abstract javax.sound.midi.Transmitter getTransmitterReferenceCounting() throws javax.sound.midi.MidiUnavailableException;
}
