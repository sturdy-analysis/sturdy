public interface  java.awt.print.Printable extends java.lang.Object
{
    public static final int PAGE_EXISTS;
    public static final int NO_SUCH_PAGE;

    public abstract int print(java.awt.Graphics, java.awt.print.PageFormat, int) throws java.awt.print.PrinterException;

    public static void <clinit>()
    {
        <java.awt.print.Printable: int NO_SUCH_PAGE> = 1;

        <java.awt.print.Printable: int PAGE_EXISTS> = 0;

        return;
    }
}
