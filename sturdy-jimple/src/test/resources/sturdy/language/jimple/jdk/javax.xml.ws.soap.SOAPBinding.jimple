public interface  javax.xml.ws.soap.SOAPBinding extends java.lang.Object implements javax.xml.ws.Binding
{
    public static final java.lang.String SOAP11HTTP_BINDING;
    public static final java.lang.String SOAP12HTTP_BINDING;
    public static final java.lang.String SOAP11HTTP_MTOM_BINDING;
    public static final java.lang.String SOAP12HTTP_MTOM_BINDING;

    public abstract java.util.Set getRoles();

    public abstract void setRoles(java.util.Set);

    public abstract boolean isMTOMEnabled();

    public abstract void setMTOMEnabled(boolean);

    public abstract javax.xml.soap.SOAPFactory getSOAPFactory();

    public abstract javax.xml.soap.MessageFactory getMessageFactory();

    public static void <clinit>()
    {
        <javax.xml.ws.soap.SOAPBinding: java.lang.String SOAP12HTTP_MTOM_BINDING> = "http://www.w3.org/2003/05/soap/bindings/HTTP/?mtom=true";

        <javax.xml.ws.soap.SOAPBinding: java.lang.String SOAP11HTTP_MTOM_BINDING> = "http://schemas.xmlsoap.org/wsdl/soap/http?mtom=true";

        <javax.xml.ws.soap.SOAPBinding: java.lang.String SOAP12HTTP_BINDING> = "http://www.w3.org/2003/05/soap/bindings/HTTP/";

        <javax.xml.ws.soap.SOAPBinding: java.lang.String SOAP11HTTP_BINDING> = "http://schemas.xmlsoap.org/wsdl/soap/http";

        return;
    }
}
