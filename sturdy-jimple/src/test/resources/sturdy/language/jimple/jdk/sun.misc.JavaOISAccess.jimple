public interface  sun.misc.JavaOISAccess extends java.lang.Object
{

    public abstract void setObjectInputFilter(java.io.ObjectInputStream, sun.misc.ObjectInputFilter);

    public abstract sun.misc.ObjectInputFilter getObjectInputFilter(java.io.ObjectInputStream);

    public abstract void checkArray(java.io.ObjectInputStream, java.lang.Class, int) throws java.io.InvalidClassException;
}
