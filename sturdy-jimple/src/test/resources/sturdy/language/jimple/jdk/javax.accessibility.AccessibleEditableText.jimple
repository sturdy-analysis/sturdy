public interface  javax.accessibility.AccessibleEditableText extends java.lang.Object implements javax.accessibility.AccessibleText
{

    public abstract void setTextContents(java.lang.String);

    public abstract void insertTextAtIndex(int, java.lang.String);

    public abstract java.lang.String getTextRange(int, int);

    public abstract void delete(int, int);

    public abstract void cut(int, int);

    public abstract void paste(int);

    public abstract void replaceText(int, int, java.lang.String);

    public abstract void selectText(int, int);

    public abstract void setAttributes(int, int, javax.swing.text.AttributeSet);
}
