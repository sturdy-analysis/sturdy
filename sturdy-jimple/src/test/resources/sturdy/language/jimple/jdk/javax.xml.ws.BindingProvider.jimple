public interface  javax.xml.ws.BindingProvider extends java.lang.Object
{
    public static final java.lang.String USERNAME_PROPERTY;
    public static final java.lang.String PASSWORD_PROPERTY;
    public static final java.lang.String ENDPOINT_ADDRESS_PROPERTY;
    public static final java.lang.String SESSION_MAINTAIN_PROPERTY;
    public static final java.lang.String SOAPACTION_USE_PROPERTY;
    public static final java.lang.String SOAPACTION_URI_PROPERTY;

    public abstract java.util.Map getRequestContext();

    public abstract java.util.Map getResponseContext();

    public abstract javax.xml.ws.Binding getBinding();

    public abstract javax.xml.ws.EndpointReference getEndpointReference();

    public abstract javax.xml.ws.EndpointReference getEndpointReference(java.lang.Class);

    public static void <clinit>()
    {
        <javax.xml.ws.BindingProvider: java.lang.String SOAPACTION_URI_PROPERTY> = "javax.xml.ws.soap.http.soapaction.uri";

        <javax.xml.ws.BindingProvider: java.lang.String SOAPACTION_USE_PROPERTY> = "javax.xml.ws.soap.http.soapaction.use";

        <javax.xml.ws.BindingProvider: java.lang.String SESSION_MAINTAIN_PROPERTY> = "javax.xml.ws.session.maintain";

        <javax.xml.ws.BindingProvider: java.lang.String ENDPOINT_ADDRESS_PROPERTY> = "javax.xml.ws.service.endpoint.address";

        <javax.xml.ws.BindingProvider: java.lang.String PASSWORD_PROPERTY> = "javax.xml.ws.security.auth.password";

        <javax.xml.ws.BindingProvider: java.lang.String USERNAME_PROPERTY> = "javax.xml.ws.security.auth.username";

        return;
    }
}
