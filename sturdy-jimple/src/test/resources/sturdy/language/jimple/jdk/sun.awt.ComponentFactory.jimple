public interface  sun.awt.ComponentFactory extends java.lang.Object
{

    public abstract java.awt.peer.CanvasPeer createCanvas(java.awt.Canvas) throws java.awt.HeadlessException;

    public abstract java.awt.peer.PanelPeer createPanel(java.awt.Panel) throws java.awt.HeadlessException;

    public abstract java.awt.peer.WindowPeer createWindow(java.awt.Window) throws java.awt.HeadlessException;

    public abstract java.awt.peer.FramePeer createFrame(java.awt.Frame) throws java.awt.HeadlessException;

    public abstract java.awt.peer.DialogPeer createDialog(java.awt.Dialog) throws java.awt.HeadlessException;

    public abstract java.awt.peer.ButtonPeer createButton(java.awt.Button) throws java.awt.HeadlessException;

    public abstract java.awt.peer.TextFieldPeer createTextField(java.awt.TextField) throws java.awt.HeadlessException;

    public abstract java.awt.peer.ChoicePeer createChoice(java.awt.Choice) throws java.awt.HeadlessException;

    public abstract java.awt.peer.LabelPeer createLabel(java.awt.Label) throws java.awt.HeadlessException;

    public abstract java.awt.peer.ListPeer createList(java.awt.List) throws java.awt.HeadlessException;

    public abstract java.awt.peer.CheckboxPeer createCheckbox(java.awt.Checkbox) throws java.awt.HeadlessException;

    public abstract java.awt.peer.ScrollbarPeer createScrollbar(java.awt.Scrollbar) throws java.awt.HeadlessException;

    public abstract java.awt.peer.ScrollPanePeer createScrollPane(java.awt.ScrollPane) throws java.awt.HeadlessException;

    public abstract java.awt.peer.TextAreaPeer createTextArea(java.awt.TextArea) throws java.awt.HeadlessException;

    public abstract java.awt.peer.FileDialogPeer createFileDialog(java.awt.FileDialog) throws java.awt.HeadlessException;

    public abstract java.awt.peer.MenuBarPeer createMenuBar(java.awt.MenuBar) throws java.awt.HeadlessException;

    public abstract java.awt.peer.MenuPeer createMenu(java.awt.Menu) throws java.awt.HeadlessException;

    public abstract java.awt.peer.PopupMenuPeer createPopupMenu(java.awt.PopupMenu) throws java.awt.HeadlessException;

    public abstract java.awt.peer.MenuItemPeer createMenuItem(java.awt.MenuItem) throws java.awt.HeadlessException;

    public abstract java.awt.peer.CheckboxMenuItemPeer createCheckboxMenuItem(java.awt.CheckboxMenuItem) throws java.awt.HeadlessException;

    public abstract java.awt.dnd.peer.DragSourceContextPeer createDragSourceContextPeer(java.awt.dnd.DragGestureEvent) throws java.awt.dnd.InvalidDnDOperationException, java.awt.HeadlessException;

    public abstract java.awt.peer.FontPeer getFontPeer(java.lang.String, int);

    public abstract java.awt.peer.RobotPeer createRobot(java.awt.Robot, java.awt.GraphicsDevice) throws java.awt.AWTException, java.awt.HeadlessException;

    public abstract sun.awt.datatransfer.DataTransferer getDataTransferer();
}
