public interface  com.sun.security.jgss.ExtendedGSSContext extends java.lang.Object implements org.ietf.jgss.GSSContext
{

    public abstract java.lang.Object inquireSecContext(com.sun.security.jgss.InquireType) throws org.ietf.jgss.GSSException;

    public abstract void requestDelegPolicy(boolean) throws org.ietf.jgss.GSSException;

    public abstract boolean getDelegPolicyState();
}
