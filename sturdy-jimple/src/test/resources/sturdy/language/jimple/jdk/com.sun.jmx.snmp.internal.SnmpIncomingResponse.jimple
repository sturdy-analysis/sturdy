public interface  com.sun.jmx.snmp.internal.SnmpIncomingResponse extends java.lang.Object
{

    public abstract java.net.InetAddress getAddress();

    public abstract int getPort();

    public abstract com.sun.jmx.snmp.SnmpSecurityParameters getSecurityParameters();

    public abstract void setSecurityCache(com.sun.jmx.snmp.internal.SnmpSecurityCache);

    public abstract int getSecurityLevel();

    public abstract int getSecurityModel();

    public abstract byte[] getContextName();

    public abstract com.sun.jmx.snmp.SnmpMsg decodeMessage(byte[], int, java.net.InetAddress, int) throws com.sun.jmx.snmp.SnmpStatusException, com.sun.jmx.snmp.SnmpSecurityException;

    public abstract com.sun.jmx.snmp.SnmpPdu decodeSnmpPdu() throws com.sun.jmx.snmp.SnmpStatusException;

    public abstract int getRequestId(byte[]) throws com.sun.jmx.snmp.SnmpStatusException;

    public abstract java.lang.String printMessage();
}
