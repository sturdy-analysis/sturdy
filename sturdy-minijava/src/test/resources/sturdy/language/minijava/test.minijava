class Factorial{
    public static void main(String[] args){
        System.out.println(Fac.ComputeFac(10));
    }
}

class Fac {
    public int ComputeFac(int num){
        int num_aux ;
        if (num > 1)
            num_aux = 1 ;
        else
            num_aux = num * 2 ;
        return num_aux ;
    }
}

