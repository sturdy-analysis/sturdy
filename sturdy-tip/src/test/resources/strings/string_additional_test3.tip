// This example shows how prefix and suffix analysis could tell us, that no matter what branch of the if gets executed,
// employeeBonusQuery would start with a SQL update statement and end with a semicolon.

main(){
    var companyProfit, employeeBonusQuery;
    companyProfit = 50000;
    if (companyProfit > 100000){
        employeeBonusQuery = "UPDATE employees SET bonus=0;";
    } else{
        employeeBonusQuery = "UPDATE employees SET bonus=1000;";
    }
    return s;

}
