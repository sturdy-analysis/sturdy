main() {

    var i, j, k, x;
    i = 0;
    j = 0;
    x = 0;

    while (10 > i) {
        i = i + 1;
        j = 0;
        while(10 > j) {
            j = j + 1;
            k = 0;
            while(10 > k) {
                k = k + 1;
                x = x + 10;
            }
        }
    }

    return x;
}