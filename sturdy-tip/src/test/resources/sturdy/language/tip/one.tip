// if filtered:
//   innermost -> stack -> eval -> ...
// else
//   eval -> ...


main() {
  var x, y;
  x = 0;
  y = 0;
  while (10 > x) {
    x = x + 1;
    while (10 > y) {
      y = y + 1;
    }
  }
  return x;
}