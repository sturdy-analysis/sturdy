filter(x) {
  var y;
  if (x > 0)
    y = 1;
  else
    y = x / 0;
  return y;
}

main() {
  var r1, i, r2;
  r1 = filter(42);
  assert(r1 == 1);
  i = input;
  r1 = i;
  r2 = filter(i);
  assert(r1 == i);
  assert(r2 == 1);
  assert(i > 0); // because otherwise filter must have failed
  return 0;
}

