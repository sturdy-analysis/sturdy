
main() {
    var x,y,z;
    x = 5;
    y = 10;
    z = 20;
    while (x > 0) {
        while (y > 0) {
            while (z > 0) {
                if (x == 0) {
                    output x;
                }
                else {
                    z = z - 1;
                }
            }
            if (z == 0) {
                output z;
            }
            else {
                y = y - 1;
            }
        }
        if (y == 0) {
            output z;
        }
        else {
            x = x - 1;
        }
    }
    return y;
}
