one(n) {
  var r;
  if (n == 0) {
    r = 1;
  } else {
    r = one(n - 1);
  }
  return r;
}

setValToResult(n, value, result) {
  var r;
    if (n == 0) {
      r = 1;
      *result = value;
    } else {
      r = setValToResult(n - 1, value, result);
    }
    return r;
}


f1(dummy) {
  var x, r;
  r = 0;
  x = 0;
  x = one(5);
  r = 1;

  x = one(5);
  r = -1;
  x = one(5);
  return r;
}


f2(dummy) {
  var x, r, i;
  r = 0;
  x = 0;
  i = 0;
  x = one(5);

  while (10 > i) {
    i = i + 1;
    x = one(5);
  }
  return i;
}

f3(dummy) {
  var x, result;
  result = alloc 0;
  x = setValToResult(5, 0, result);
  x = setValToResult(5, 1, result);
  return *result;
}

main() {
  return f1(43);
}