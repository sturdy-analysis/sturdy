fib(n) {
    var res;
    if (n == 1) {
        res = 1;
    } else {
        res = f(n - 1) + fib(n - 1);
    }
    return res;
}


f(x) {
    var r;
    if (x == input) {
        r = 1;
    } else {
        r = fib(10) + f(x - 1) + fib(x) + fib(x) + fib(x);
    }
    return r;
}

main() {
    return f(10);
}
