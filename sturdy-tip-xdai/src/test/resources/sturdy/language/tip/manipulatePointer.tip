id(val) {
  return val;
}

one(n, valuePointer, value) {
  var r;
  if (n == 0) {
    r = 1;
    *valuePointer = id(value);
  } else {
    r = one(n - 1, valuePointer, value);
  }
  return r;
}

main() {
  var x, r, d;
  d = 0;
  r = alloc d;
  x = 0;
  x = one(5, r, d);
  d = 1;
  x = one(5, r, d);
  return *r;
}