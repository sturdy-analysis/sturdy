main() {
    var x,y,y1,y2,y3;
    x = 0;
    y = alloc x;
    if (input) {
      x = 1;
      y1 = alloc x;
    } else {
      x = 2;
      y1 = alloc x;
    }
    y2 = alloc x;
    x = 3;
    y3 = alloc x;

    // y is unaffected
    assert (*y == 0);

    // *y1 == [1,2]
    assert (*y1 > 0);
    assert (3 > *y1);

    // *y2 == [1,2]
    assert (*y2 > 0);
    assert (3 > *y2);

    // *y1 == x == *y2, but the following assertion fails because [1,2] == [1,2] is not true
    // assert (*y1 == *y2);

    assert (*y3 == 3);

    return *y2;
}
