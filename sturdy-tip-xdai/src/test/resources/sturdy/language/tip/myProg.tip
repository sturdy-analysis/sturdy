/* "Mapping" a function over a list-like sequence of heap-allocated cells. Orginating from examples/a1.tip. */

f(l) {
  var r;
  if (l==null){
      r=0;
  } else {
      r= 1 + f(*l);
  }
  return r;
}

inc(i) {
  return i+1;
}

