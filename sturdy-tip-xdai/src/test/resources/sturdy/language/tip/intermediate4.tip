fib(n) {
    var res;
    if (n == 1) {
        res = 1;
    } else {
        res = fib(n - 2) + fib(n - 1);
    }
    return res;
}


f(x) {
    var r;
    if (x == input) {
        r = 1;
    } else if (x == input) {
        r = fib(10) + fib(x);
    } else {
        r = r + x * f(x - 1);
    }
    return r;
}

main() {
    return f(10);
}
